                <div>
                    <span class="text-blue-800 font-bold text-sm xl:text-base">+977 9807654321</span><br />
                    <p class="text-xs xl:text-sm">24hrs customer support</p>
                </div>
            </div>
        </div>

        <div id="mobile-menu" class="hidden lg:hidden absolute left-0 top-full z-50 w-full bg-gray-700 shadow-lg">
            <div class="mx-auto flex max-w-[1340px] flex-col px-4 md:px-8 py-4 text-white">
                <a href="#" class="border-b border-white/10 py-3">Home</a>
                <a href="#aboutus" class="border-b border-white/10 py-3">About Us</a>
