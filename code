<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Everest Base Camp Trek Graph</title>

    <!-- tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- chart js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            font-family: Arial, sans-serif;
        }
    </style>
</head>

<body class="bg-gray-100 p-6">

    <section class="max-w-7xl mx-auto bg-[#ECECEC] rounded-2xl p-6 shadow-lg">

        <!-- title -->
        <h1
            class="text-center text-3xl md:text-5xl font-extrabold uppercase tracking-wide text-[#2E478B] mb-8">
            Everest Base Camp Trek
        </h1>

        <!-- chart -->
        <div class="h-[500px]">
            <canvas id="ebcChart"></canvas>
        </div>

    </section>

    <script>

        const labels = [
            "Kathmandu",
            "Lukla",
            "Phakding",
            "Namche Bazaar",
            "Tengboche",
            "Dingboche",
            "Lobuche",
            "Gorak Shep",
            "Everest Base Camp",
            "Kala Patthar",
            "Pheriche",
            "Namche Bazaar",
            "Lukla",
            "Kathmandu"
        ];

        const altitude = [
            1400,
            2860,
            2610,
            3440,
            3860,
            4410,
            4940,
            5164,
            5364,
            5545,
            4240,
            3440,
            2860,
            1400
        ];

        const ctx = document.getElementById("ebcChart");

        new Chart(ctx, {

            type: "line",

            data: {

                labels: labels,

                datasets: [{
                    label: "Altitude",
                    data: altitude,

                    borderColor: "#2E478B",
                    backgroundColor: "#2E478B",

                    borderWidth: 3,

                    pointRadius: 6,
                    pointHoverRadius: 8,

                    tension: 0.2,

                    fill: false
                }]
            },

            options: {

                responsive: true,
                maintainAspectRatio: false,

                interaction: {
                    intersect: false,
                    mode: "index"
                },

                plugins: {

                    legend: {
                        display: false
                    },

                    tooltip: {

                        backgroundColor: "#2E478B",

                        callbacks: {

                            title: function (context) {
                                return labels[context[0].dataIndex];
                            },

                            label: function (context) {
                                return "Altitude: " + context.parsed.y.toLocaleString() + "m";
                            }
                        }
                    }
                },

                scales: {

                    y: {

                        min: 1000,
                        max: 6000,

                        ticks: {

                            stepSize: 1000,

                            callback: function (value) {
                                return value.toLocaleString() + "m";
                            }
                        },

                        title: {
                            display: true,
                            text: "Altitude (m)",
                            font: {
                                size: 16,
                                weight: "bold"
                            }
                        },

                        grid: {
                            borderDash: [5, 5]
                        }
                    },

                    x: {

                        ticks: {
                            maxRotation: 0,
                            minRotation: 0,
                            font: {
                                size: 11,
                                weight: "bold"
                            }
                        },

                        grid: {
                            display: false
                        }
                    }
                }
            },

            plugins: [

                {
                    id: "customLabels",

                    afterDatasetsDraw(chart) {

                        const { ctx } = chart;

                        const meta = chart.getDatasetMeta(0);

                        meta.data.forEach((point, index) => {

                            ctx.save();

                            ctx.fillStyle = "#222";

                            ctx.font = "12px Arial";

                            ctx.textAlign = "center";

                            ctx.fillText(
                                altitude[index].toLocaleString() + "m",
                                point.x,
                                point.y - 15
                            );

                            // step number circle
                            ctx.beginPath();

                            ctx.arc(point.x, point.y + 38, 10, 0, 2 * Math.PI);

                            ctx.fillStyle = "#2E478B";

                            ctx.fill();

                            ctx.fillStyle = "#fff";

                            ctx.font = "10px Arial";

                            ctx.fillText(index + 1, point.x, point.y + 42);

                            ctx.restore();
                        });
                    }
                }

            ]
        });

    </script>

</body>

</html>