    <!-- nav start -->
    <nav class="sticky top-0 z-50 hidden lg:flex bg-black py-2 items-center  justify-center">
        <div class="flex w-full max-w-[1340px] mx-auto items-center justify-between px-4 md:px-8 lg:px-0 gap-4">
            <ul class="hidden lg:flex gap-16 py-2 font-16 text-white">
                <li>
                    <a href="#">Home</a>
                </li>
                <li>
                    <a href="#aboutus">About Us</a>
                </li>
