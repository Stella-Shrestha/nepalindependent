    <!-- hero section start -->
    <section class="py-16 lg:py-24">
        <div class="flex justify-center items-center flex-col gap-3">
            <p class="uppercase font-bold text-blue-600 text-sm">Booking</p>
            <h4 class="text-3xl font-bold leading-tight text-state-950 md:text-4xl lg:text-[56px]">Book Now</h4>
        </div>
    </section>
    <!-- hero section end -->

    <main class="min-h-screen flex items-center justify-center px-4 py-10">
        <div
            class="w-full max-w-4xl overflow-hidden rounded-[28px] bg-white shadow-[0_24px_80px_rgba(15,23,42,0.12)] border border-slate-200">
            <div class="grid lg:grid-cols-[1.1fr_0.9fr]">
                <section
                    class="p-8 md:p-12 lg:p-14 bg-gradient-to-br from-[#0F172A] via-[#1E40FF] to-[#2563EB] text-white">
                    <p class="text-xs uppercase tracking-[0.35em] text-white/70 mb-4">Booking</p>
                    <h1 class="text-3xl md:text-5xl font-black leading-tight mb-5">Book Your Trip</h1>
                    <p class="text-white/80 text-base md:text-lg leading-relaxed max-w-xl">
                        Send your trip details and we’ll confirm availability, pricing, and the next steps for your
                        trek.
                    </p>
                    <div class="mt-10 grid grid-cols-2 gap-4 text-sm text-white/85">
                        <div class="rounded-2xl bg-white/10 p-4 backdrop-blur">
                            <p class="font-semibold mb-1">Fast response</p>
                            <p>We usually reply within one business day.</p>
                        </div>
                        <div class="rounded-2xl bg-white/10 p-4 backdrop-blur">
                            <p class="font-semibold mb-1">Secure planning</p>
                            <p>Confirm the right dates before you travel.</p>
                        </div>
                    </div>
                </section>

                <section class="p-8 md:p-12 lg:p-14">
                    <h2 class="text-2xl font-extrabold mb-2">Trip Request Form</h2>
                    <p class="text-slate-500 mb-8">Tell us who is traveling and when you want to go.</p>

                    <form class="space-y-4">
                        <input type="text" placeholder="Full name"
                            class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-blue-500">
                        <input type="email" placeholder="Email address"
                            class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-blue-500">
                        <input type="tel" placeholder="Phone number"
                            class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-blue-500">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <input type="date"
                                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-blue-500">
                            <input type="number" min="1" placeholder="No. of travelers"
                                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-blue-500">
                        </div>
                        <textarea rows="4" placeholder="Special requests"
                            class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-blue-500"></textarea>
                        <button type="submit"
                            class="w-full rounded-xl bg-blue-600 px-4 py-3 font-semibold text-white hover:bg-blue-700 transition">
                            Confirm Booking
                        </button>
                    </form>

                    <a href="trek.html"
                        class="mt-6 inline-flex text-sm font-semibold text-blue-600 hover:text-blue-800 transition">
                        Back to trek page
                    </a>
                </section>
            </div>
        </div>
    </main>

